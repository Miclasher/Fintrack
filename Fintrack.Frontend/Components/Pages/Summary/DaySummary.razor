@page "/daySummary"
@rendermode InteractiveServer
@inject ISummaryService SummaryService
@inject ISummaryExportService SummaryExportService
@inject ITransactionTypeService TransactionTypeService
@inject IJSRuntime JsRuntime

<h3>DaySummary</h3>
@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <p class="text-danger">@ErrorMessage</p>
}

<div class="container">
    <h5>Enter a day to get summary for it:</h5>
    <InputDate @bind-Value="Date" />
    <button class="btn btn-primary m-3" @onclick="GetDaySummary">Get Day Summary</button>
    <button class="btn btn-success m-3" @onclick="ExportDaySummaryToExcel">Export to Excel</button>
</div>

@if (Summary is not null)
{
    <div class="container">
        <dl>
            <div class="m-3">
                <dt>Income</dt>
                <dd class="text-success">@Summary.TotalIncome</dd>
            </div>
            <div class="m-3">
                <dt>Expenses</dt>
                <dd class="text-danger">@(Summary.TotalExpense * -1)</dd>
            </div>
        </dl>
        <div class="m-3">
            <dt>Diagram</dt>
            @if (GetDiagramTotal() > 0)
            {
                <div class="progress" style="height: 30px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @GetIncomePercentage()%;">
                        Income @Summary.TotalIncome
                    </div>
                    <div class="progress-bar bg-danger" role="progressbar" style="width: @GetExpensePercentage()%;">
                        Expenses @(Summary.TotalExpense * -1)
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted">No data to build diagram.</p>
            }
        </div>
        <table class="table m-3">
            <thead>
                <tr>
                    <th>Amount</th>
                    <th>Date</th>
                    <th>Comment</th>
                    <th>Transaction Type</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var financialOperation in Summary.Operations)
                {
                    var transactionType = TransactionTypes.First(tt => tt.Id == financialOperation.TransactionTypeId);
                    <tr>

                        <td>
                            @if (transactionType.IsExpense)
                            {
                                <p class="text-danger">-@financialOperation.Amount</p>
                            }
                            else
                            {
                                <p class="text-success">@financialOperation.Amount</p>
                            }
                        </td>
                        <td>@financialOperation.Date</td>
                        <td>@financialOperation.UserComment</td>
                        <td>@transactionType.Name</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private DateOnly Date { get; set; } = DateOnly.FromDateTime(DateTime.UtcNow);
    private SummaryDTO Summary { get; set; } = null!;
    private IEnumerable<TransactionTypeDTO> TransactionTypes { get; set; } = new List<TransactionTypeDTO>();
    private string? ErrorMessage { get; set; }

    protected async override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            TransactionTypes = await TransactionTypeService.GetAllAsync();
        }
    }

    private async Task GetDaySummary()
    {
        try
        {
            Summary = await SummaryService.GetDaySummary(Date);
            ErrorMessage = null;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task ExportDaySummaryToExcel()
    {
        try
        {
            var fileBytes = await SummaryExportService.ExportDaySummaryToExcel(Date);
            var fileName = $"day-summary-{Date:yyyy-MM-dd}.xlsx";
            var fileBase64 = Convert.ToBase64String(fileBytes);

            await JsRuntime.InvokeVoidAsync("downloadFileFromBytes", fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", fileBase64);

            ErrorMessage = null;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private decimal GetDiagramTotal()
    {
        if (Summary is null)
        {
            return 0;
        }

        return Summary.TotalIncome + Math.Abs(Summary.TotalExpense);
    }

    private string GetIncomePercentage()
    {
        var total = GetDiagramTotal();
        if (total == 0)
        {
            return "0";
        }

        return Math.Round((Summary.TotalIncome / total) * 100, 2).ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private string GetExpensePercentage()
    {
        var total = GetDiagramTotal();
        if (total == 0)
        {
            return "0";
        }

        return Math.Round((Math.Abs(Summary.TotalExpense) / total) * 100, 2).ToString(System.Globalization.CultureInfo.InvariantCulture);
    }
}
